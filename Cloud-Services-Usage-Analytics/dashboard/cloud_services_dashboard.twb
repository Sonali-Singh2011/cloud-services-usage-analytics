    <worksheet name='Highest Usage Month'>
      <table>
        <view>
          <datasources>
            <datasource caption='cloud_usage (cloud_usage_analytics)' name='federated.0sla24l0xua8921c9k9n81rkmwc4' />
          </datasources>
          <datasource-dependencies datasource='federated.0sla24l0xua8921c9k9n81rkmwc4'>
            <column caption='Api Requests' datatype='integer' name='[api_requests]' role='measure' type='quantitative' />
            <column-instance column='[usage_date]' derivation='Month' name='[mn:usage_date:ok]' pivot='key' type='ordinal' />
            <column caption='Usage Date' datatype='date' name='[usage_date]' role='dimension' type='ordinal' />
            <column caption='Usage Hours' datatype='real' name='[usage_hours]' role='measure' type='quantitative' />
            <column-instance column='[usage_date]' derivation='Year' name='[yr:usage_date:ok]' pivot='key' type='ordinal' />
          </datasource-dependencies>
          <filter class='categorical' column='[federated.0sla24l0xua8921c9k9n81rkmwc4].[mn:usage_date:ok]'>
            <groupfilter count='1' end='top' function='end' units='records' user:ui-marker='end' user:ui-top-by-field='true'>
              <groupfilter direction='DESC' expression='SUM([usage_hours])' function='order' user:ui-marker='order'>
